generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model LoveTap {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  userId    String?
  count     Int      @default(1)

  @@index([timestamp])
  @@map("love_taps")
}

model ImageSnap {
  id          String   @id @default(cuid())
  s3Key       String
  contentType String
  sizeBytes   Int
  uploadedAt  DateTime @default(now())
  expiresAt   DateTime
  userId      String?

  @@index([uploadedAt])
  @@map("image_snaps")
}
