# ===========================================
# Environment Variables
# ===========================================
# Copy this file to .env for local development.
# Production variables are configured in the Vercel dashboard.

# Database (Supabase PostgreSQL)
DATABASE_URL=

# Upstash Redis (serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Pusher (server-side)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Pusher (client-side, exposed to browser)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# App config
WEEKLY_TAP_GOAL=50

# Auth (admin panel)
ADMIN_PASSWORD=
JWT_SECRET=

# AWS S3 (image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Image feature
IMAGE_DISPLAY_SECONDS=5
IMAGE_MAX_SIZE_MB=4.5
